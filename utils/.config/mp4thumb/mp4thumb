#!/usr/bin/env bash
set -Eeuo pipefail
shopt -s inherit_errexit

readonly SCRIPT_NAME=$(basename "${BASH_SOURCE[0]}")
readonly SCRIPT_PATH=$(realpath "${BASH_SOURCE[0]}")
readonly VERSION="1.0.0"

VERBOSE=0

log() { printf '[%s] %s\n' "$(date '+%H:%M:%S')" "$*" >&2; }
warn() { printf '[%s] WARN %s\n' "$(date '+%H:%M:%S')" "$*" >&2; }
error() { printf '[%s] ERROR %s\n' "$(date '+%H:%M:%S')" "$*" >&2; }
debug() { ((VERBOSE)) && printf '[%s] DEBUG %s\n' "$(date '+%H:%M:%S')" "$*" >&2 || true; }

usage() {
  : "Print usage to stderr."
  cat >&2 <<EOF
Usage: $SCRIPT_NAME [OPTIONS]

Interactively select an mp4 file and extract its first frame as a PNG.
The output file is saved alongside the source file with a .png extension.

Options:
  -h, --help       Show this help message
  -v, --verbose    Enable debug output
  --version        Show version

Dependencies: ffmpeg, fzf, fd, chafa, kitten (kitty)
EOF
}

check_dependencies() {
  : "Verify all required tools are installed; exit with usage if any are missing."
  local deps=("ffmpeg" "fzf" "fd" "chafa" "kitten")
  local missing=()

  for dep in "${deps[@]}"; do
    command -v "$dep" &>/dev/null || missing+=("$dep")
  done

  if ((${#missing[@]} > 0)); then
    error "Missing dependencies: ${missing[*]}"
    usage
    exit 1
  fi
}
preview() {
  local input="$1"
  local tmp cols lines pane_top pane_left pane_width pane_height

  tmp="$(mktemp --suffix=.png)" || return 1
  trap 'rm -f "$tmp"' RETURN

  ffmpeg -loglevel error -y -i "$input" -frames:v 1 "$tmp" || return 1

  cols="${FZF_PREVIEW_COLUMNS:-}"
  lines="${FZF_PREVIEW_LINES:-}"

  [[ -z "$cols" || -z "$lines" ]] && return 1

  # fzf provides pane geometry; kitten can place using cell coordinates
  pane_top="${FZF_PREVIEW_TOP:-0}"
  pane_left="${FZF_PREVIEW_LEFT:-0}"
  pane_width="${FZF_PREVIEW_COLUMNS:-$cols}"
  pane_height="${FZF_PREVIEW_LINES:-$lines}"

  # avoid bottom-row scroll glitch
  ((pane_height > 1)) && pane_height=$((pane_height - 1))

  kitten icat \
    --stdin=no \
    --transfer-mode=stream \
    --unicode-placeholder \
    --place "${pane_width}x${pane_height}@${pane_left}x${pane_top}" \
    "$tmp"

  printf '\n'
}
extract_thumb() {
  : "Extract the first frame of the given mp4 file and save it as a PNG alongside the source.
    Args: input_file"
  local input="$1"
  local output

  output="${input%.*}.png"
  debug "Input:  $input"
  debug "Output: $output"

  ffmpeg -i "$input" -frames:v 1 -q:v 2 "$output" -y 2>/dev/null
  log "Saved: $output"
}

main() {
  : "Parse arguments, prompt for mp4 file selection, and extract the first frame as PNG."
  while (($# > 0)); do
    case "$1" in
    -h | --help)
      usage
      exit 0
      ;;
    --version)
      printf '%s %s\n' "$SCRIPT_NAME" "$VERSION"
      exit 0
      ;;
    -v | --verbose)
      VERBOSE=1
      shift
      ;;
    --preview)
      preview "$2"
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      error "Unknown option: $1"
      usage
      exit 1
      ;;
    *) break ;;
    esac
  done

  check_dependencies

  local selected
  selected=$(fd -e mp4 . | fzf \
    --prompt="Select MP4: " \
    --preview="$SCRIPT_PATH --preview {}" \
    --preview-window=right:60%) || {
    warn "No file selected."
    exit 0
  }

  [[ -z "$selected" ]] && {
    warn "No file selected."
    exit 0
  }

  extract_thumb "$selected"
}

main "$@"
