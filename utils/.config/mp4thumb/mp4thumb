#!/usr/bin/env bash
set -Eeuo pipefail
shopt -s inherit_errexit

readonly SCRIPT_NAME=$(basename "${BASH_SOURCE[0]}")
readonly VERSION="1.0.0"

VERBOSE=0

log()   { printf '[%s] %s\n'   "$(date '+%H:%M:%S')" "$*" >&2; }
warn()  { printf '[%s] WARN %s\n'  "$(date '+%H:%M:%S')" "$*" >&2; }
error() { printf '[%s] ERROR %s\n' "$(date '+%H:%M:%S')" "$*" >&2; }
debug() { (( VERBOSE )) && printf '[%s] DEBUG %s\n' "$(date '+%H:%M:%S')" "$*" >&2 || true; }

usage() {
    : "Print usage to stderr."
    cat >&2 <<EOF
Usage: $SCRIPT_NAME [OPTIONS]

Interactively select an mp4 file and extract its first frame as a PNG.
The output file is saved alongside the source file with a .png extension.

Options:
  -h, --help       Show this help message
  -v, --verbose    Enable debug output
  --version        Show version

Dependencies: ffmpeg, fzf, fd
EOF
}

check_dependencies() {
    : "Verify all required tools are installed; exit with usage if any are missing."
    local deps=("ffmpeg" "fzf" "fd")
    local missing=()

    for dep in "${deps[@]}"; do
        command -v "$dep" &>/dev/null || missing+=("$dep")
    done

    if (( ${#missing[@]} > 0 )); then
        error "Missing dependencies: ${missing[*]}"
        usage
        exit 1
    fi
}

select_file() {
    : "Use fd to enumerate mp4 files under PWD and present them in fzf for selection.
    Prints the selected file path to stdout, or returns 1 if none selected."
    local selected
    selected=$(fd -e mp4 . | fzf --prompt="Select MP4: " --preview="echo {}") || return 1
    [[ -z "$selected" ]] && return 1
    printf '%s' "$selected"
}

extract_thumb() {
    : "Extract the first frame of the given mp4 file and save it as a PNG alongside the source.
    Args: input_file"
    local input="$1"
    local output

    output="${input%.*}.png"
    debug "Input:  $input"
    debug "Output: $output"

    ffmpeg -i "$input" -frames:v 1 -q:v 2 "$output" -y 2>/dev/null
    log "Saved: $output"
    printf '%s' "$output"
}

main() {
    : "Parse arguments, prompt for mp4 file selection, and extract the first frame as PNG."
    while (( $# > 0 )); do
        case "$1" in
            -h|--help)    usage; exit 0 ;;
            --version)    printf '%s %s\n' "$SCRIPT_NAME" "$VERSION"; exit 0 ;;
            -v|--verbose) VERBOSE=1; shift ;;
            --)           shift; break ;;
            -*) error "Unknown option: $1"; usage; exit 1 ;;
            *)  break ;;
        esac
    done

    check_dependencies

    local input
    input=$(select_file) || { warn "No file selected."; exit 0; }

    extract_thumb "$input"
}

main "$@"
