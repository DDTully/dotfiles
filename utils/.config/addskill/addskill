#!/usr/bin/env bash
set -Eeuo pipefail
shopt -s inherit_errexit

SCRIPT_NAME=$(basename "${BASH_SOURCE[0]}")
readonly SCRIPT_NAME
readonly VERSION="1.0.0"

log()   { printf '[%s] %s\n'   "$(date '+%H:%M:%S')" "$*" >&2; }
error() { printf '[%s] ERROR %s\n' "$(date '+%H:%M:%S')" "$*" >&2; }

usage() {
    : "Print usage to stderr."
    cat >&2 <<EOF
Usage: $SCRIPT_NAME <src>

Copies a skill to dotfiles/skills/.claude/skills and dotfiles/skills/.opencode/skills.

Args:
  src    Source skill directory

Examples:
  $SCRIPT_NAME ~/my-new-skill
  $SCRIPT_NAME /path/to/skill
EOF
}

main() {
    if (( $# == 0 )); then
        error "Missing src argument"
        usage
        exit 1
    fi

    local src="$1"
    local name
    name=$(basename "$src")
    local dotfiles_dir="$HOME/dotfiles"
    local dest_claude="$dotfiles_dir/skills/.claude/skills/$name"
    local dest_opencode="$dotfiles_dir/skills/.opencode/skills/$name"

    if [[ ! -d "$src" ]]; then
        error "Not a directory: $src"
        exit 1
    fi

    mkdir -p "$dotfiles_dir/skills/.claude/skills" "$dotfiles_dir/skills/.opencode/skills"

    log "Copying $src -> $dest_claude"
    rm -rf "$dest_claude"
    cp -r "$src" "$dest_claude"

    log "Copying $src -> $dest_opencode"
    rm -rf "$dest_opencode"
    cp -r "$src" "$dest_opencode"

    log "Done."
}

main "$@"