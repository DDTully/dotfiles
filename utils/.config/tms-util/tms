#!/usr/bin/env bash
set -euo pipefail

BASE_DIRECTORY="$HOME/"
INSTALL_PATH="/usr/bin/tms"

FZF_OPTS=(--layout=reverse --border --height=~40%)

: "list herdr workspaces as tab-separated 'label\tworkspace_id' lines"
list_workspaces() {
  herdr workspace list | jq -r '.result.workspaces[] | "\(.label)\t\(.workspace_id)"'
}

: "print the workspace_id for an exact label match, if any"
workspace_id_for_label() {
  list_workspaces | awk -F'\t' -v l="$1" '$1 == l { print $2; exit }'
}

: "select directory and open it as a new herdr workspace with editor/server/agent/working/ssh tabs"
new_herdr_workspace() {
  selected=$(find "$BASE_DIRECTORY" -mindepth 1 -maxdepth 4 -type d \
    -not -path '*/.*' 2>/dev/null |
    fzf "${FZF_OPTS[@]}" --algo=v2 --prompt="New session: ")

  if [ -z "$selected" ]; then
    return 1
  fi

  session_name=$(basename "$selected")
  session_path=$selected

  # resolve name collisions by appending an incrementing suffix
  base_name="$session_name"
  suffix=1
  while [ -n "$(workspace_id_for_label "$session_name")" ]; do
    session_name="${base_name}-${suffix}"
    ((suffix++))
  done

  # this shell is already an attached herdr pane (nested `herdr` invocations
  # are refused), so the whole layout is built over the socket API and the
  # new workspace simply takes over the current view via --focus
  created=$(herdr workspace create --cwd "$session_path" --label "$session_name" --focus)
  workspace_id=$(jq -r '.result.workspace.workspace_id' <<<"$created")
  editor_tab_id=$(jq -r '.result.tab.tab_id' <<<"$created")
  editor_pane_id=$(jq -r '.result.root_pane.pane_id' <<<"$created")

  # window 1: Editor (the workspace's initial tab/pane)
  herdr tab rename "$editor_tab_id" "editor" >/dev/null
  herdr pane run "$editor_pane_id" "pact; nvim; clear"

  # window 2: Server (plain shell)
  herdr tab create --workspace "$workspace_id" --cwd "$session_path" \
    --label "server" --no-focus >/dev/null

  # window 3: Agent
  agent=$(herdr tab create --workspace "$workspace_id" --cwd "$session_path" \
    --label "agent" --no-focus)
  agent_tab_id=$(jq -r '.result.tab.tab_id' <<<"$agent")
  agent_pane_id=$(jq -r '.result.root_pane.pane_id' <<<"$agent")
  herdr pane run "$agent_pane_id" "opencode"

  # window 4: Working (plain shell)
  herdr tab create --workspace "$workspace_id" --cwd "$session_path" \
    --label "working" --no-focus >/dev/null

  # window 5: SSH (plain shell)
  herdr tab create --workspace "$workspace_id" --cwd "$session_path" \
    --label "ssh" --no-focus >/dev/null

  herdr tab focus "$agent_tab_id" >/dev/null
}

: "select an existing workspace and bring it into focus"
attach_herdr_workspace() {
  local rows label target_id

  rows=$(list_workspaces)
  if [ -z "$rows" ]; then
    echo "No herdr workspaces running"
    return 1
  fi

  label=$(cut -f1 <<<"$rows" | fzf "${FZF_OPTS[@]}" --prompt="Select session: ")
  if [ -z "$label" ]; then
    return 1
  fi
  target_id=$(workspace_id_for_label "$label")

  herdr workspace focus "$target_id"
}

: "select a running workspace to close"
kill_herdr_workspace() {
  local rows label target_id

  rows=$(list_workspaces)
  if [ -z "$rows" ]; then
    return 1
  fi

  label=$(cut -f1 <<<"$rows" | fzf "${FZF_OPTS[@]}" --prompt="Kill session: ")
  if [ -z "$label" ]; then
    return 1
  fi
  target_id=$(workspace_id_for_label "$label")

  herdr workspace close "$target_id"
  echo "Killed session: $label"
}

install() {
  SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"

  if [ ! -f "$INSTALL_PATH" ]; then
    read -rp "Install tms to $INSTALL_PATH? [y/N] (skip with --no-install) " choice
    case "${choice,,}" in
    y | yes)
      sudo cp "$SCRIPT_PATH" "$INSTALL_PATH"
      sudo chmod +x "$INSTALL_PATH"
      echo "tms installed successfully: $SCRIPT_PATH -> $INSTALL_PATH"
      ;;
    esac
  fi
}

reload_herdr_config() {
  herdr server reload-config
  echo "herdr config reloaded"
}

main() {
  if [[ "${1:-}" != "--no-install" ]]; then
    install
  fi

  while true; do
    choice=$(printf 'NEW\nATTACH\nKILL\nRELOAD CONFIG\nEXIT' |
      fzf "${FZF_OPTS[@]}" --prompt="herdr session manager: ")
    case $choice in
    "NEW")
      new_herdr_workspace && break
      ;;
    "ATTACH")
      attach_herdr_workspace && break
      ;;
    "KILL")
      kill_herdr_workspace
      ;;
    "RELOAD CONFIG")
      reload_herdr_config
      ;;
    "EXIT" | "")
      break
      ;;
    *)
      break
      ;;
    esac
  done
}

main "$@"
