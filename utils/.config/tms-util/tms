#!/usr/bin/env bash
set -euo pipefail

BASE_DIRECTORY="$HOME/"
INSTALL_PATH="/usr/bin/tms"

FZF_OPTS=(--layout=reverse --border --height=~40%)

# select directory and create new session
new_tmux_session() {
  selected=$(find "$BASE_DIRECTORY" -mindepth 1 -maxdepth 4 -type d \
    -not -path '*/.*' 2>/dev/null |
    fzf "${FZF_OPTS[@]}" --algo=v2 --prompt="New session: ")

  if [ -z "$selected" ]; then
    return 1
  fi

  session_name=$(basename "$selected")
  session_path=$selected

  # resolve name collisions by appending an incrementing suffix
  base_name="$session_name"
  suffix=1
  while tmux has-session -t "$session_name" 2>/dev/null; do
    session_name="${base_name}-${suffix}"
    ((suffix++))
  done

  tmux new-session -d -s "$session_name" -c "$session_path" -n "editor"
  tmux send-keys -t "${session_name}:editor" "pact; nvim; clear" C-m

  # window 2: Server (plain shell)
  tmux new-window -t "$session_name:" -c "$session_path" -n "server"

  # window 3: OpenCode
  tmux new-window -t "$session_name:" -c "$session_path" -n "agent"
  tmux send-keys -t "${session_name}:agent" "opencode" C-m

  # window 4: Working (plain shell)
  tmux new-window -t "$session_name:" -c "$session_path" -n "working"

  # window 5: SSH (plain shell)
  tmux new-window -t "$session_name:" -c "$session_path" -n "ssh"

  tmux select-window -t "${session_name}:agent"

  if [ -n "${TMUX:-}" ]; then
    tmux switch-client -t "$session_name"
  else
    tmux attach-session -t "$session_name"
  fi
}

# select current running session and attach to it
attach_tmux_session() {
  if ! tmux list-sessions &>/dev/null; then
    echo "No tmux sessions running"
    return 1
  fi

  session_name=$(tmux list-sessions -F "#{session_name}" |
    fzf "${FZF_OPTS[@]}" --prompt="Select session: ")

  if [ -z "$session_name" ]; then
    return 1
  fi

  if [ -n "${TMUX:-}" ]; then
    tmux switch-client -t "$session_name"
  else
    tmux attach-session -t "$session_name"
  fi
}

# select current running session to kill
kill_tmux_session() {
  if ! tmux list-sessions &>/dev/null; then
    return 1
  fi

  session_name=$(tmux list-sessions -F "#{session_name}" |
    fzf "${FZF_OPTS[@]}" --prompt="Kill session: ")

  if [ -z "$session_name" ]; then
    return 1
  fi

  tmux kill-session -t "$session_name"
  echo "Killed session: $session_name"
}

# ctrl+b d — interactive detach
detach_tmux_session() {
  if [ -z "${TMUX:-}" ]; then
    return 1
  fi

  current=$(tmux display-message -p '#S')
  read -rp "Detach from \"${current}\"? [y/N] " choice
  case "${choice,,}" in
  y | yes) tmux detach-client ;;
  *) return 1 ;;
  esac
}

install() {
  SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"

  if [ ! -f "$INSTALL_PATH" ]; then
    read -rp "Install tms to $INSTALL_PATH? [y/N] (skip with --no-install) " choice
    case "${choice,,}" in
    y | yes)
      sudo cp "$SCRIPT_PATH" "$INSTALL_PATH"
      sudo chmod +x "$INSTALL_PATH"
      echo "tms installed successfully: $SCRIPT_PATH -> $INSTALL_PATH"
      ;;
    esac
  fi
}

reload_tmux_config() {
  tmux source-file ~/.tmux.conf
  echo "tmux config reloaded"
}

main() {
  if [[ "${1:-}" != "--no-install" ]]; then
    install
  fi

  while true; do
    choice=$(printf 'NEW\nATTACH\nDETACH\nKILL\nRELOAD CONFIG\nEXIT' |
      fzf "${FZF_OPTS[@]}" --prompt="tmux session manager: ")
    case $choice in
    "NEW")
      new_tmux_session && break
      ;;
    "ATTACH")
      attach_tmux_session && break
      ;;
    "DETACH")
      detach_tmux_session && break
      ;;
    "KILL")
      kill_tmux_session
      ;;
    "RELOAD CONFIG")
      reload_tmux_config
      ;;
    "EXIT" | "")
      break
      ;;
    *)
      break
      ;;
    esac
  done
}

main "$@"
